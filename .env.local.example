# ─── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# ─── Anthropic (Claude) — plans Premium & Business ───────
ANTHROPIC_API_KEY=sk-ant-xxxx

# ─── GitHub Models (GPT-4o-mini) — plan Gratuit ──────────
# Token GitHub classique, aucune permission requise
GITHUB_TOKEN=ghp_xxxx

# ─── Meta (Facebook OAuth) ───────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=https://yourdomain.com/api/auth/meta/callback

# ─── Instagram (OAuth direct sans Page Facebook) ─────────
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=https://yourdomain.com/api/auth/instagram/callback

# ─── Ayrshare (plans payants) ────────────────────────────
AYRSHARE_API_KEY=your_ayrshare_api_key

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_PREMIUM=price_xxxx
STRIPE_PRICE_BUSINESS=price_xxxx

# ─── Google Gemini (génération d'images) ─────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Sécurité ────────────────────────────────────────────
# Clé AES-256 pour chiffrement tokens OAuth (32 bytes = 64 chars hex)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key

# Secret partagé entre Vercel Cron et l'app
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_cron_secret

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
